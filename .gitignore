# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ide files
.vscode
.idea

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (security: never commit actual .env files)
.env
.env*.local
.env.development
.env.production

# Exception: DO commit .env.example files (templates only)
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
